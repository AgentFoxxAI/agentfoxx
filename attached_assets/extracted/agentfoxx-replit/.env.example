# AgentFoxx Environment Variables for Replit

# n8n Webhook URL (get this from your n8n workflow after deployment)
N8N_WEBHOOK_URL=https://your-n8n-instance.app.n8n.cloud/webhook/agentfoxx

# Node environment
NODE_ENV=production

# Port (Replit sets this automatically, but you can override for local testing)
PORT=3000
