# =============================================================================
# Telesign MCP Server - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your production values.
# NEVER commit .env to version control.
# =============================================================================

# --- Telesign API Credentials (Required) ---
# Obtain from: https://portal.telesign.com/account/keys
TELESIGN_CUSTOMER_ID=your-customer-id-here
TELESIGN_API_KEY=your-base64-api-key-here

# --- Telesign API Configuration ---
# Base URL for Telesign REST API (enterprise endpoint)
TELESIGN_API_BASE_URL=https://rest-api.telesign.com

# --- Connection & Timeout Settings ---
# HTTP connect timeout in seconds
TELESIGN_CONNECT_TIMEOUT=5.0
# HTTP read timeout in seconds
TELESIGN_READ_TIMEOUT=30.0
# Maximum concurrent connections
TELESIGN_MAX_CONNECTIONS=100
# Maximum connections per host
TELESIGN_MAX_CONNECTIONS_PER_HOST=20

# --- Retry Configuration ---
# Maximum retry attempts for transient failures (5xx)
TELESIGN_MAX_RETRIES=3
# Initial backoff delay in seconds (exponential with jitter)
TELESIGN_RETRY_BASE_DELAY=1.0

# --- Circuit Breaker ---
# Number of consecutive failures before circuit opens
TELESIGN_CIRCUIT_FAILURE_THRESHOLD=5
# Seconds before attempting recovery after circuit opens
TELESIGN_CIRCUIT_RECOVERY_TIMEOUT=30

# --- Rate Limiting ---
# Maximum API requests per minute (adjust per Telesign contract)
TELESIGN_RATE_LIMIT_PER_MINUTE=100

# --- Logging ---
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# Log format: json (production) or console (development)
LOG_FORMAT=json

# --- Server ---
# MCP transport: stdio (default) or sse
MCP_TRANSPORT=stdio
# Host for SSE transport (if used)
MCP_HOST=0.0.0.0
# Port for SSE transport (if used)
MCP_PORT=8000
